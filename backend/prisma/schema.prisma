datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("JUDGE")
  name      String
  isChairman Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  scores    Score[]
}

model Candidate {
  id          String   @id @default(uuid())
  number      Int      @unique
  firstName   String
  lastName    String
  bio         String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  scores      Score[]
  votes       AudienceVote[]
  snapshots   ScoreAnalyticsSnapshot[]
}

model PageantSection {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., Swimwear, Evening Gown, Q&A
  weight      Float    // e.g., 0.3 for 30%
  description String?
  isActive    Boolean  @default(true)
  criteria    Criteria[]
  scores      Score[]
}

model Criteria {
  id               String         @id @default(uuid())
  pageantSectionId String
  name             String         // e.g., Poise, Beauty, Confidence
  maxPoints        Float          // e.g., 100
  weight           Float          // e.g., 0.4 for 40% of the section
  section          PageantSection @relation(fields: [pageantSectionId], references: [id], onDelete: Cascade)
  scores           ScoreDetail[]
}

model Score {
  id               String         @id @default(uuid())
  judgeId          String
  candidateId      String
  pageantSectionId String
  computedScore    Float          // Total weighted score for this section
  isSyncedFromOffline Boolean     @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  judge            User           @relation(fields: [judgeId], references: [id])
  candidate        Candidate      @relation(fields: [candidateId], references: [id])
  section          PageantSection @relation(fields: [pageantSectionId], references: [id])
  details          ScoreDetail[]

  @@unique([judgeId, candidateId, pageantSectionId])
}

model ScoreDetail {
  id         String   @id @default(uuid())
  scoreId    String
  criteriaId String
  points     Float    // Raw points awarded
  score      Score    @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  criteria   Criteria @relation(fields: [criteriaId], references: [id])
}

model AudienceVote {
  id               String   @id @default(uuid())
  candidateId      String
  deviceId         String   // Hashed fingerprint or device id
  voteDate         DateTime @default(now()) // Stored date to check limit
  candidate        Candidate @relation(fields: [candidateId], references: [id])

  @@unique([deviceId, candidateId]) // Prevent multi-voting by the same device for the same candidate
}

model OfflineScoreQueue {
  id            String   @id @default(uuid())
  judgeId       String
  payload       String
  synced        Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model ScoreAnalyticsSnapshot {
  id            String   @id @default(uuid())
  candidateId   String
  sectionId     String
  totalScore    Float
  rankPosition  Int
  computedAt    DateTime @default(now())
  candidate     Candidate @relation(fields: [candidateId], references: [id])
}

model QRVoteSession {
  id            String   @id @default(uuid())
  qrCodeToken   String   @unique
  expiresAt     DateTime
  isActive      Boolean  @default(true)
}

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}
